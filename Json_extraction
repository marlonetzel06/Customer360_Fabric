class ValueExtractor:
    """Handles extraction and formatting of values from Power BI objects"""
    
    @staticmethod
    def extract_value(value: Any) -> Any:
        """Extract and properly format values for Power BI theme schema"""
        if isinstance(value, dict):
            return ValueExtractor._extract_dict_value(value)
        elif isinstance(value, list):
            return ValueExtractor._extract_list_value(value)
        return value
    
    @staticmethod
    def _extract_dict_value(value: Dict[str, Any]) -> Any:
        """Extract value from dictionary objects"""
        if "expr" in value:
            return ValueExtractor._extract_expression_value(value["expr"])
        
        if "solid" in value and "color" in value["solid"]:
            return ValueExtractor._extract_color_value(value)
        
        # Recursively parse nested dictionaries
        result = {}
        for k, v in value.items():
            extracted = ValueExtractor.extract_value(v)
            if extracted is not None:
                result[k] = extracted
        return result if result else None
    
    @staticmethod
    def _extract_expression_value(expr: Any) -> Any:
        """Extract values from expression objects"""
        if isinstance(expr, dict):
            # Block ALL Measure expressions
            if "Measure" in expr:
                return None
            
            if "Literal" in expr:
                return ValueExtractor._extract_literal_value(expr["Literal"])
            
            if "ThemeDataColor" in expr:
                return {"expr": expr}
            
            # Skip ResourcePackageItem
            if "ResourcePackageItem" in expr:
                return None
        
        return None
    
    @staticmethod
    def _extract_literal_value(literal: Any) -> Any:
        """Extract value from literal objects"""
        if isinstance(literal, dict) and "Value" in literal:
            val = literal["Value"]
            if isinstance(val, str):
                return ValueExtractor._parse_string_value(val)
            return val
        return None
    
    @staticmethod
    def _parse_string_value(val: str) -> Union[bool, int, float, str]:
        """Parse string values to appropriate types"""
        if not isinstance(val, str):
            return val
            
        # Remove quotes
        if len(val) >= 2:
            if (val.startswith("'") and val.endswith("'")) or (val.startswith('"') and val.endswith('"')):
                val = val[1:-1]
        
        val_lower = val.lower()
        
        # Boolean handling
        if val_lower in ("true", "1"):
            return True
        elif val_lower in ("false", "0"):
            return False
        
        # Special handling for alignment values that might be numeric strings
        if val in ["0", "1", "2", "3"]:
            return int(val)
        
        # Numeric handling with suffix
        if val and val[-1] in ("D", "L"):
            num_str = val[:-1]
            try:
                if '.' in num_str:
                    return float(num_str)
                else:
                    return int(num_str)
            except ValueError:
                return val
        
        # Try to convert to number
        try:
            if '.' in val:
                return float(val)
            else:
                return int(val)
        except ValueError:
            return val
    
    @staticmethod
    def _extract_color_value(value: Dict[str, Any]) -> Optional[Dict[str, Any]]:
        """Extract color values from color objects"""
        if "solid" in value and "color" in value["solid"]:
            color_value = ValueExtractor.extract_value(value["solid"]["color"])
            if color_value is not None:
                if isinstance(color_value, str) or (isinstance(color_value, dict) and "expr" in color_value):
                    return {"solid": {"color": color_value}}
        return None
    
    @staticmethod
    def _extract_list_value(value: List[Any]) -> Optional[List[Any]]:
        """Extract values from list objects"""
        extracted_list = []
        for item in value:
            extracted = ValueExtractor.extract_value(item)
            if extracted is not None:
                extracted_list.append(extracted)
        return extracted_list if extracted_list else None


class PropertyValidator:
    """Validates and cleans properties for Power BI theme schema compliance"""
    
    @staticmethod
    def is_valid_for_theme(prop_key: str, prop_value: Any, is_card_visual: bool = False, 
                          visual_type: Optional[str] = None, parent_object: Optional[str] = None) -> bool:
        """Check if a property is valid for Power BI themes"""
        # Use appropriate invalid properties set
        invalid_props = CARD_INVALID_PROPERTIES if is_card_visual else INVALID_THEME_PROPERTIES
        
        if prop_key in invalid_props:
            return False
        
        # Check for expressions to block
        if isinstance(prop_value, dict) and "expr" in prop_value:
            expr_str = str(prop_value["expr"])
            # Block ResourcePackageItem and Measure expressions
            if "ResourcePackageItem" in expr_str or "Measure" in expr_str:
                return False
        
        return True
    
    def clean_property(prop_key: str, prop_value: Any, parent_object: Optional[str] = None, 
                    is_card_visual: bool = False, visual_type: Optional[str] = None) -> Any:
        """Clean and validate properties for schema compliance"""
        if not PropertyValidator.is_valid_for_theme(prop_key, prop_value, is_card_visual, visual_type, parent_object):
            return None
        
        # Handle boolean properties
        if PropertyValidator._is_boolean_property(prop_key):
            return PropertyValidator._to_boolean(prop_value)
        
        # Handle alignment properties
        if PropertyValidator._is_alignment_property(prop_key):
            return PropertyValidator._normalize_alignment(prop_key, prop_value, parent_object, visual_type)
        
        if PropertyValidator._is_numeric_property(prop_key):
            result = PropertyValidator._to_number(prop_value)
            if result is not None:
                # Apply font size limit
                if prop_key == "fontSize" and result > MAX_FONT_SIZE:
                    print(f"  ⚠️  Font size {result} exceeds maximum of {MAX_FONT_SIZE}, capping to {MAX_FONT_SIZE}")
                    return MAX_FONT_SIZE
                return result
        
        # Handle font family - FIXED VERSION
        if prop_key == "fontFamily" and isinstance(prop_value, str):
            # First, handle escaped quotes by replacing them with regular quotes
            cleaned = prop_value.replace('\\"', '"')
            
            # Remove any leading/trailing quotes from the entire string
            cleaned = cleaned.strip("'\"")
            
            # Split by comma to process each font
            parts = cleaned.split(',')
            cleaned_parts = []
            
            for part in parts:
                part = part.strip()
                
                # Skip empty parts
                if not part:
                    continue
                
                # Remove quotes around individual font names
                part = part.strip("'\"")
                
                # Skip Power BI specific web font references (wf_*)
                if part.startswith('wf_'):
                    continue
                
                # Generic font families that should not be quoted
                generic_fonts = ['serif', 'sans-serif', 'monospace', 'cursive', 'fantasy', 
                            'helvetica', 'arial', 'verdana', 'tahoma', 'georgia', 'times']
                
                # Check if this needs quotes (has spaces and is not a generic font)
                if ' ' in part and part.lower() not in generic_fonts:
                    # Use single quotes for consistency
                    part = f"'{part}'"
                
                cleaned_parts.append(part)
            
            # Join with proper formatting
            return ', '.join(cleaned_parts) if cleaned_parts else 'Segoe UI'
        
        # Handle fill rule
        if prop_key == "fillRule":
            return PropertyValidator._fix_fill_rule(prop_value)
        
        # Handle data bars
        if prop_key == "dataBars":
            extracted_value = ValueExtractor.extract_value(prop_value)
            if extracted_value is not None:
                return PropertyValidator._fix_data_bars_colors(extracted_value)
            return None
        
        # Handle color properties
        if PropertyValidator._is_color_property(prop_key):
            return PropertyValidator._validate_color_property(prop_value)
        
        return prop_value


    @staticmethod
    def _is_boolean_property(prop_key: str) -> bool:
        """Check if property should be treated as boolean"""
        return prop_key in {
            "show", "Show", "backgroundShow", "showLabel", "wordWrap", "titleWrap",
            "fontBold", "fontItalic", "fontUnderline", "bold", "italic", "underline",
            "customizePadding", "alignBaselines", "keepLayerOrder", "customizeSpacing",
            "reverseOrder", "flipOverlap", "ignorePadding"
        }
    
    @staticmethod
    def _is_numeric_property(prop_key: str) -> bool:
        """Check if property should be treated as numeric"""
        return any(pattern in prop_key for pattern in [
            "fontSize", "Size", "borderWidth", "Width", "outlineWidth", 
            "padding", "margin", "spacing", "transparency", "opacity",
            "precision", "decimalPlaces", "Blur", "Offset", "radius",
            "labelSpace", "outerPadding", "cellPadding", "calloutSize",
            "maxTiles", "rectangleRoundedCurve", "spaceBelowSubTitle", "spaceBelowTitleArea"
        ])
    
    @staticmethod
    def _is_color_property(prop_key: str) -> bool:
        """Check if property is color-related"""
        return (prop_key.endswith("Color") or prop_key == "color" or 
                prop_key in ["fill", "background", "border", "barColor"])
    
    @staticmethod
    def _is_alignment_property(prop_key: str) -> bool:
        """Check if property is alignment-related"""
        return prop_key in ["alignment", "verticalAlignment", "horizontalAlignment"]
    
    @staticmethod
    def _to_boolean(value: Any) -> bool:
        """Convert value to boolean"""
        if isinstance(value, bool):
            return value
        if isinstance(value, str):
            return value.strip().lower() in ("true", "1", "yes", "on")
        if isinstance(value, (int, float)):
            return bool(value)
        return False
    
    @staticmethod
    def _to_number(value: Any) -> Optional[Union[int, float]]:
        """Convert value to number"""
        if isinstance(value, (int, float)) and not isinstance(value, bool):
            return value
        if isinstance(value, str):
            try:
                if '.' not in value and 'e' not in value.lower():
                    return int(value)
                else:
                    return float(value)
            except ValueError:
                return None
        return None
    
    @staticmethod
    def _normalize_alignment(prop_key: str, value: Any, parent_object: Optional[str], 
                        visual_type: Optional[str]) -> Union[str, int]:
        """Normalize alignment values - handle both numeric and string inputs"""
        
        # For pivot table headers, use numeric values
        if visual_type == "pivotTable" and parent_object in ["columnHeaders", "rowHeaders"]:
            if isinstance(value, (int, float)):
                return int(value)
            elif isinstance(value, str):
                value_lower = value.lower().strip()
                if prop_key in ["horizontalAlignment", "alignment"]:
                    if value_lower in ["left", "l", "0"]:
                        return 0
                    elif value_lower in ["center", "c", "centre", "1"]:
                        return 1
                    elif value_lower in ["right", "r", "2"]:
                        return 2
                    elif value_lower in ["automatic", "auto", "3"]:
                        return 3
                    else:
                        return 1
                else:  # verticalAlignment
                    if value_lower in ["top", "t", "0"]:
                        return 0
                    elif value_lower in ["middle", "m", "center", "c", "centre", "1"]:
                        return 1
                    elif value_lower in ["bottom", "b", "2"]:
                        return 2
                    else:
                        return 1
            else:
                return 1
        
        # For all other visuals, use lowercase string values
        else:
            if isinstance(value, (int, float)):
                value_int = int(value)
                if prop_key in ["horizontalAlignment", "alignment"]:
                    if value_int == 0:
                        return "left"
                    elif value_int == 1:
                        return "center"
                    elif value_int == 2:
                        return "right"
                    elif value_int == 3:
                        return "automatic"
                    else:
                        return "center"
                else:  # verticalAlignment
                    if value_int == 0:
                        return "top"
                    elif value_int == 1:
                        return "middle"
                    elif value_int == 2:
                        return "bottom"
                    else:
                        return "middle"
            elif isinstance(value, str):
                value_lower = value.lower().strip()
                if prop_key in ["horizontalAlignment", "alignment"]:
                    if value_lower in ["left", "l", "0"]:
                        return "left"
                    elif value_lower in ["center", "c", "centre", "1"]:
                        return "center"
                    elif value_lower in ["right", "r", "2"]:
                        return "right"
                    elif value_lower in ["automatic", "auto", "3"]:
                        return "automatic"
                    else:
                        return "center"
                else:  # verticalAlignment
                    if value_lower in ["top", "t", "0"]:
                        return "top"
                    elif value_lower in ["middle", "m", "center", "c", "centre", "1"]:
                        return "middle"
                    elif value_lower in ["bottom", "b", "2"]:
                        return "bottom"
                    else:
                        return "middle"
            else:
                # Default values - lowercase
                return "center" if prop_key in ["horizontalAlignment", "alignment"] else "middle"
    
    @staticmethod
    def _fix_fill_rule(fill_rule: Any) -> Optional[Dict[str, Any]]:
        """Fix fillRule to match schema requirements - ENHANCED"""
        if isinstance(fill_rule, dict) and "linearGradient2" in fill_rule:
            gradient = fill_rule.get("linearGradient2", {})
            fixed_rule = {"linearGradient2": {}}
            
            # Ensure min and max have proper structure
            for bound in ["min", "max"]:
                if bound in gradient:
                    bound_data = gradient[bound]
                    if isinstance(bound_data, dict):
                        fixed_bound = {}
                        
                        # Ensure value property exists
                        if "value" in bound_data:
                            fixed_bound["value"] = bound_data["value"]
                        else:
                            fixed_bound["value"] = 0 if bound == "min" else 100
                        
                        # Fix color to be a valid hex color
                        if "color" in bound_data:
                            color = bound_data["color"]
                            if isinstance(color, dict) and "solid" in color:
                                color_val = color["solid"].get("color", "#000000")
                                if ColorPalette.is_valid_hex_color(color_val):
                                    fixed_bound["color"] = color_val
                                else:
                                    fixed_bound["color"] = "#000000"
                            elif isinstance(color, str) and ColorPalette.is_valid_hex_color(color):
                                fixed_bound["color"] = color
                            else:
                                fixed_bound["color"] = "#000000"
                        else:
                            fixed_bound["color"] = "#000000" if bound == "min" else "#FFFFFF"
                        
                        fixed_rule["linearGradient2"][bound] = fixed_bound
                else:
                    # Add default bounds if missing
                    fixed_rule["linearGradient2"][bound] = {
                        "value": 0 if bound == "min" else 100,
                        "color": "#000000" if bound == "min" else "#FFFFFF"
                    }
            
            return fixed_rule
        return None
    
    @staticmethod
    def _fix_data_bars_colors(data_bars: Dict[str, Any]) -> Dict[str, Any]:
        """Fix dataBars colors to match schema requirements"""
        if not isinstance(data_bars, dict):
            return data_bars
        
        for prop in ["positiveColor", "negativeColor", "axisColor"]:
            if prop not in data_bars:
                data_bars[prop] = {
                    "solid": {"color": DEFAULT_DATA_BARS_COLORS.get(prop, "#000000")}
                }
            elif prop in data_bars:
                data_bars[prop] = PropertyValidator._fix_color_value(
                    data_bars[prop], 
                    DEFAULT_DATA_BARS_COLORS.get(prop, "#000000")
                )
        
        # Remove invalid properties
        keys_to_remove = [k for k in data_bars.keys() if k not in VALID_DATA_BARS_PROPS]
        for k in keys_to_remove:
            del data_bars[k]
        
        return data_bars
    

    @staticmethod
    def validate_card_id(id_value: str) -> str:
        """Validate and clean $id values for card visuals"""
        if id_value in VALID_CARD_IDS:
            return id_value
        
        # Check if it's alphanumeric (after removing underscores)
        cleaned_id = id_value.replace('_', '').replace('-', '')
        if cleaned_id.isalnum():
            # Return the original if it was valid
            return id_value
        
        # Default to "default" for invalid IDs
        return "default"

    @staticmethod
    def _fix_color_value(color_val: Any, default_color: str) -> Dict[str, Any]:
        """Fix individual color values"""
        if isinstance(color_val, dict) and "solid" in color_val and "color" in color_val["solid"]:
            inner_color = color_val["solid"]["color"]
            if isinstance(inner_color, str) and ColorPalette.is_valid_hex_color(inner_color):
                return color_val
            elif isinstance(inner_color, dict) and "expr" in inner_color:
                return color_val  # Valid ThemeDataColor
        elif isinstance(color_val, str) and ColorPalette.is_valid_hex_color(color_val):
            return {"solid": {"color": color_val}}
        
        return {"solid": {"color": default_color}}
    
    @staticmethod
    def _validate_color_property(prop_value: Any) -> Optional[Dict[str, Any]]:
        """Validate and format color properties"""
        # Simple hex string - wrap in proper fill structure
        if isinstance(prop_value, str) and ColorPalette.is_valid_hex_color(prop_value):
            return {"solid": {"color": prop_value}}
        
        # Already formatted color object
        if isinstance(prop_value, dict):
            if "solid" in prop_value and "color" in prop_value["solid"]:
                color = prop_value["solid"]["color"]
                
                # Hex color string
                if isinstance(color, str) and ColorPalette.is_valid_hex_color(color):
                    return prop_value
                
                # Theme color reference
                if (isinstance(color, dict) and "expr" in color and 
                    isinstance(color["expr"], dict) and "ThemeDataColor" in color["expr"]):
                    return prop_value
            
            # Check if it's a bare expression that needs wrapping
            elif "expr" in prop_value and isinstance(prop_value["expr"], dict):
                if "ThemeDataColor" in prop_value["expr"]:
                    # Wrap the expression in solid
                    return {"solid": {"color": prop_value}}
        
        return None


class VisualProcessor:
    """Base class for processing different visual types"""
    
    def __init__(self, visual_type: str, page_type: str = "regular"):
        self.visual_type = visual_type
        self.page_type = page_type
        self.palette = ColorPalette()
        self.is_card_visual = visual_type in CARD_VISUALS
    
    @staticmethod
    def _get_valid_items(object_items: List[Any]) -> Iterator[Dict[str, Any]]:
        """Yield valid items that have properties"""
        if isinstance(object_items, list):
            for item in object_items:
                if isinstance(item, dict) and "properties" in item and isinstance(item["properties"], dict):
                    yield item
    
    def should_process_object(self, object_key: str) -> bool:
        """Determine if an object should be processed for this visual type"""
        # Always process slicer-specific objects
        if self.visual_type in INTERACTION_STATE_VISUALS and object_key in SLICER_PRESERVE_OBJECTS:
            return True
            
        if self.is_card_visual:
            # Process almost everything for card visuals
            return object_key not in CARD_DYNAMIC_OBJECTS
        else:
            return object_key not in DYNAMIC_CONTENT_OBJECTS
    
    def extract_colors_from_config(self, config: Dict[str, Any]) -> None:
        """Extract colors from visual configuration for the palette"""
        for object_name, items in config.items():
            if not isinstance(items, list):
                continue
            
            for item in items:
                if not isinstance(item, dict):
                    continue
                
                for prop_key, prop_value in item.items():
                    if prop_key == "$id":
                        continue
                    
                    if PropertyValidator._is_color_property(prop_key):
                        if isinstance(prop_value, dict) and "solid" in prop_value:
                            color = prop_value["solid"].get("color")
                            if isinstance(color, str) and ColorPalette.is_valid_hex_color(color):
                                self.palette.add_color(color)
    
    @staticmethod
    def clean_name(name: str) -> str:
        """Clean display name for preset naming"""
        if not isinstance(name, str):
            return "Default"
        
        # Remove non-alphanumeric characters and replace spaces
        cleaned = re.sub(r'[^\w\s-]', '', name).replace(' ', '_')
        
        # Ensure name is not empty
        if not cleaned:
            return "Default"
            
        # Ensure name doesn't start with a number
        if cleaned[0].isdigit():
            cleaned = f"Style_{cleaned}"
            
        # Limit length
        if len(cleaned) > 50:
            cleaned = cleaned[:50]
            
        return cleaned


class CardVisualProcessor(VisualProcessor):
    """Specialized processor for card visuals, preserving all formatting properties."""
    
    def __init__(self, visual_type: str, page_type: str = "regular"):
        super().__init__(visual_type, page_type)
        self.wildcard_config = None
    
    def should_process_object(self, object_key: str) -> bool:
        """Card visuals should process almost all objects"""
        # Only skip truly dynamic content
        return True  # Process everything!
    def process_visual_config(self, objects: Dict[str, Any], display_name: str, preset_counter: int) -> Optional[VisualConfig]:
        """Process card visual configuration, preserving all states."""
        # Card visuals CAN have presets, unlike interaction state visuals
        visual_config = {}
        # Process all container objects too
        all_objects = objects.copy()
        
        for object_key, object_items in all_objects.items():
            # Skip internal metadata
            if object_key in ['stylePreset', 'general', 'visualTooltip', 'visualHeader']:
                continue

            if not isinstance(object_items, list):
                continue
            
            processed_items = []
            for item in self._get_valid_items(object_items):
                properties = item.get("properties", {})
                selector = item.get("selector")

                processed_props = self._process_item_properties(properties, object_key)

                if processed_props:
                    theme_item = processed_props.copy()
                    
                    # Add $id for objects that need it - FIXED for card visuals
                    if object_key in CARD_OBJECTS_NEEDING_ID:
                        # For card visuals, only use valid $id values
                        if selector and isinstance(selector, dict) and "id" in selector:
                            selector_id = selector["id"]
                            # Check if it's a valid card ID
