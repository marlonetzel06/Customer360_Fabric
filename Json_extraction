    def _build_visual_styles_with_standardized_fonts(self) -> Dict[str, Any]:
        """Build visual styles with standardized font settings and Default/Global page logic"""
        visual_styles = {"*": {}}
        
        # Add font settings to global wildcard
        for object_name, settings in self.font_settings.items():
            if settings:
                visual_styles["*"][object_name] = [settings]
        
        # Add other global settings
        for object_name, items in self.global_settings.items():
            if object_name not in visual_styles["*"]:
                visual_styles["*"][object_name] = items
        
        # Process each visual type
        all_visual_types = set(self.visual_configs.keys()) | set(self.default_configs.keys())
        
        for visual_type in all_visual_types:
            configs = self.visual_configs.get(visual_type, [])
            default_config = self.default_configs.get(visual_type)
            
            # Card visuals are a special case that supports presets
            if visual_type in CARD_VISUALS:
                visual_styles[visual_type] = {}
                
                # Use default config as wildcard if available
                if default_config:
                    wildcard = self._remove_font_properties(default_config.copy())
                    if "general" not in wildcard:
                        wildcard["general"] = [{"keepLayerOrder": True}]
                    visual_styles[visual_type]["*"] = wildcard
                elif visual_type in self.card_wildcard_configs:
                    wildcard = self._remove_font_properties(self.card_wildcard_configs[visual_type].copy())
                    if "general" not in wildcard:
                        wildcard["general"] = [{"keepLayerOrder": True}]
                    visual_styles[visual_type]["*"] = wildcard
                
                # Add presets from regular pages
                for config in configs:
                    preset_config = self._remove_font_properties(config.config.copy())
                    if "general" not in preset_config:
                        preset_config["general"] = [{"keepLayerOrder": True}]
                    visual_styles[visual_type][config.preset_name] = preset_config
            
            # Table/matrix/pivot visuals don't support presets
            elif visual_type in NO_PRESET_VISUALS:
                merged_config = self._remove_font_properties(default_config.copy()) if default_config else {}
                
                for config in configs:
                    cleaned_config = self._remove_font_properties(config.config.copy())
                    for object_name, items in cleaned_config.items():
                        if object_name not in merged_config:
                            merged_config[object_name] = []
                        merged_config[object_name].extend(items)
                
                if merged_config:
                    for object_name in merged_config:
                        seen = []
                        unique_items = []
                        for item in merged_config[object_name]:
                            item_str = json.dumps(item, sort_keys=True)
                            if item_str not in seen:
                                seen.append(item_str)
                                unique_items.append(item)
                        merged_config[object_name] = unique_items
                    
                    visual_styles[visual_type] = {
                        "*": merged_config
                    }
            
            # Interaction state visuals with special handling
            elif visual_type in INTERACTION_STATE_VISUALS:
                # These visuals ONLY support wildcard, no presets allowed
                wildcard_config = self._remove_font_properties(default_config.copy()) if default_config else {}
                
                for config in configs:
                    cleaned_config = self._remove_font_properties(config.config.copy())
                    for object_name, items in cleaned_config.items():
                        if object_name not in wildcard_config:
                            wildcard_config[object_name] = []
                        wildcard_config[object_name].extend(items)
                
                # Add collected interaction states
                if visual_type in self._interaction_states_collection:
                    for object_name, states in self._interaction_states_collection[visual_type].items():
                        if object_name not in wildcard_config:
                            wildcard_config[object_name] = []
                        # Remove font properties from interaction states too
                        for state in states:
                            cleaned_state = {}
                            for prop, value in state.items():
                                if prop == "$id":
                                    cleaned_state[prop] = value
                                elif (object_name not in TEXT_OBJECTS or 
                                      prop not in COMMON_TEXT_PROPERTIES or
                                      object_name not in self.font_settings or
                                      prop not in self.font_settings[object_name] or
                                      str(value) != str(self.font_settings[object_name][prop])):
                                    cleaned_state[prop] = value
                            if cleaned_state:
                                wildcard_config[object_name].append(cleaned_state)
                
                # Build the visual style - ONLY wildcard, no presets
                if wildcard_config:
                    wildcard = {}
                    
                    # Add all objects to wildcard
                    for object_name, items in wildcard_config.items():
                        # Remove duplicates while preserving $id items
                        seen_items = {}
                        unique_items = []
                        for item in items:
                            # For items with $id, use $id as key
                            if "$id" in item:
                                key = f"$id:{item['$id']}"
                            else:
                                key = json.dumps(item, sort_keys=True)
                            
                            if key not in seen_items:
                                seen_items[key] = True
                                unique_items.append(item)
                        wildcard[object_name] = unique_items
                    
                    visual_styles[visual_type] = {"*": wildcard}
                    # NO PRESETS - don't add any named configurations
                    
            # Standard visuals with preset support - PRESERVE INDIVIDUAL PRESETS
            else:
                if default_config or configs:
                    visual_styles[visual_type] = {}
                    
                    # Use default config as wildcard if available
                    if default_config:
                        cleaned_wildcard = self._remove_font_properties(default_config.copy())
                        visual_styles[visual_type]["*"] = cleaned_wildcard
                    elif configs:
                        visual_styles[visual_type]["*"] = {"stylePreset": [{"name": configs[0].preset_name}]}
                    
                    # Add global styling for specific visual types
                    self._add_global_styling(visual_styles[visual_type], visual_type)
                    
                    # Add individual presets
                    for config in configs:
                        if config.config:
                            cleaned_config = self._remove_font_properties(config.config.copy())
                            visual_styles[visual_type][config.preset_name] = self._process_preset_config(cleaned_config)

        return {k: v for k, v in visual_styles.items() if v}
    
    def _add_global_styling(self, visual_style: Dict[str, Any], visual_type: str) -> None:
        """Add global styling for specific visual types"""
        if visual_type in BAR_COLUMN_VISUALS:
            # Add white second series with border
            second_bar_style = {
                "seriesIndex": 1,
                "fill": {
                    "solid": {
                        "color": create_theme_color_reference(7, 0)
                    }
                },
                "borderColor": {"solid": {"color": "#252423"}},
                "borderWidth": 1
            }
            
            if "dataPoint" not in visual_style["*"]:
                visual_style["*"]["dataPoint"] = []
            visual_style["*"]["dataPoint"].append(second_bar_style)
        
        if visual_type == "clusteredColumnChart":
            if "columnLayout" not in visual_style["*"]:
                visual_style["*"]["columnLayout"] = []
            visual_style["*"]["columnLayout"].append({
                "reverseOrder": True,
                "flipOverlap": True
            })
    
    def _save_theme_file(self, theme_output: Dict[str, Any], clean_report_name: str, output_dir: str) -> str:
        """Save theme file with unique naming"""
        base_filename = f"{clean_report_name}_merged_theme"
        theme_filename = f"{base_filename}.json"
        theme_path = os.path.join(output_dir, theme_filename)
        
        counter = 1
        while os.path.exists(theme_path):
            theme_filename = f"{base_filename}_{counter}.json"
            theme_path = os.path.join(output_dir, theme_filename)
            counter += 1
        
        with open(theme_path, "w", encoding="utf-8") as theme_file:
            json.dump(theme_output, theme_file, indent=2, ensure_ascii=False)
        
        return theme_path

    def _print_summary(self, theme_path: str, report_name: str, theme_output: Dict[str, Any]) -> None:
        """Print generation summary"""
        print(f"\n{'='*80}")
        print(f"✅ Power BI Theme Generator - Cleaned Version")
        print(f"📁 File: {theme_path}")
        print(f"📋 Report: {report_name}")
        print(f"🎨 Color palette: {len(theme_output['dataColors'])} colors")
        
        # Summary of what was found
        if self.default_configs:
            print(f"\n📊 Default page configurations:")
            for visual_type in self.default_configs:
                print(f"  - {visual_type}")
        
        if self.global_settings:
            print(f"\n🌐 Global settings extracted:")
            for setting in self.global_settings:
                print(f"  - {setting}")
        
        total_presets = 0
        
        for visual_type, config in theme_output["visualStyles"].items():
            if visual_type == "*": continue
            
            preset_count = len([k for k in config.keys() if k != "*"])
            total_presets += preset_count
            
            if visual_type in CARD_VISUALS:
                print(f"\n📊 {visual_type}: {preset_count} presets + wildcard")
            elif visual_type in INTERACTION_STATE_VISUALS:
                print(f"\n📊 {visual_type}: wildcard only (no presets allowed)")
            else:
                print(f"\n📊 {visual_type}: {preset_count} presets")
        
        print(f"\n📈 Summary:")
        print(f"  - Total visual types: {len(theme_output['visualStyles'])}")
        print(f"  - Total presets: {total_presets}")
        print("="*80)

    def _process_preset_config(self, config: Dict[str, Any]) -> Dict[str, Any]:
        """Process configuration for a preset"""
        return config

    def _remove_font_properties(self, config: Dict[str, Any]) -> Dict[str, Any]:
        """Remove font properties from configuration"""
        cleaned_config = {}
        
        for object_name, items in config.items():
            if not isinstance(items, list):
                cleaned_config[object_name] = items
                continue
            
            cleaned_items = []
            for item in items:
                if not isinstance(item, dict):
                    cleaned_items.append(item)
                    continue
                
                cleaned_item = {}
                for prop, value in item.items():
                    # Always preserve $id and selector
                    if prop in ["$id", "selector"]:
                        cleaned_item[prop] = value
                        continue
                    
                    # Skip font properties for text objects that match global settings
                    if (object_name in TEXT_OBJECTS and 
                        prop in COMMON_TEXT_PROPERTIES and
                        object_name in self.font_settings and
                        prop in self.font_settings[object_name] and
                        str(value) == str(self.font_settings[object_name][prop])):
                        continue
                    cleaned_item[prop] = value
                
                if cleaned_item:
                    cleaned_items.append(cleaned_item)
            
            if cleaned_items:
                cleaned_config[object_name] = cleaned_items
        
        return cleaned_config


