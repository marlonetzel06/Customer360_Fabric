    def _extract_common_font_settings(self) -> Dict[str, Dict[str, Any]]:
        """Extract common font settings from all visual configurations"""
        font_stats = defaultdict(lambda: defaultdict(list))
        
        # Collect from both regular configs and default configs
        all_configs = []
        for visual_type, configs in self.visual_configs.items():
            all_configs.extend(configs)
        
        # Add default configs
        for visual_type, config in self.default_configs.items():
            # Create a temporary VisualConfig object for consistency
            temp_config = VisualConfig(visual_type, "default", config, "default")
            all_configs.append(temp_config)
        
        # Collect all font properties from all visuals
        for config in all_configs:
            for object_name, items in config.config.items():
                if object_name in TEXT_OBJECTS:
                    for item in items:
                        for prop in COMMON_TEXT_PROPERTIES:
                            if prop in item:
                                # Store value with its visual context
                                font_stats[object_name][prop].append(item[prop])
        
        # Find most common values for each object type
        common_settings = {}
        for object_name, properties in font_stats.items():
            common_settings[object_name] = {}
            for prop, values in properties.items():
                if values:
                    # Find most common value
                    # For complex objects (dicts), convert to string for comparison
                    value_counts = {}
                    for val in values:
                        val_key = str(val) if isinstance(val, dict) else val
                        value_counts[val_key] = value_counts.get(val_key, 0) + 1
                    
                    # Get the most common value
                    most_common_key = max(value_counts, key=value_counts.get)
                    # Convert back from string if needed
                    for val in values:
                        if str(val) == most_common_key:
                            # Cap font size if needed
                            if prop == "fontSize" and isinstance(val, (int, float)) and val > MAX_FONT_SIZE:
                                print(f"  ⚠️  Common font size {val} for {object_name} exceeds maximum, capping to {MAX_FONT_SIZE}")
                                common_settings[object_name][prop] = MAX_FONT_SIZE
                            else:
                                common_settings[object_name][prop] = val
                            break
        
        # Set reasonable defaults if no common settings found
        if not common_settings:
            common_settings = {
                "categoryAxis": {
                    "fontSize": 11,
                    "fontFamily": "Segoe UI",
                    "fontColor": {"solid": {"color": "#666666"}}
                },
