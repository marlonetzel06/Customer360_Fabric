    def process_visual_config(self, objects: Dict[str, Any], display_name: str, preset_counter: int) -> Optional[VisualConfig]:
        """Process standard visual configuration, filtering out data-specific rules."""
        visual_config = {}
        
        # Debug logging for slicers
        is_slicer = self.visual_type in INTERACTION_STATE_VISUALS
        
        for object_key, object_items in objects.items():
            # The 'stylePreset' object from the source is internal metadata and invalid in a theme's wildcard.
            if object_key == 'stylePreset':
                continue

            # For interaction state visuals, collect interaction states separately
            if is_slicer and object_key in SLICER_OBJECTS_NEEDING_ID:  # Changed from INTERACTION_STATE_OBJECTS
                # Process all items for this object
                for item in self._get_valid_items(object_items):
                    selector = item.get("selector")
                    properties = item.get("properties", {})
                    
                    if selector and isinstance(selector, dict) and "id" in selector:
                        selector_id = selector["id"]
                        if selector_id in VALID_INTERACTION_SELECTORS:
                            # This is an interaction state - save it for wildcard
                            processed_props = {}
                            for prop_key, prop_val in properties.items():
                                if not isinstance(prop_key, str) or prop_key.startswith("dynamic"):
                                    continue
                                
                                extracted_val = ValueExtractor.extract_value(prop_val)
                                if extracted_val is not None:
                                    cleaned_val = PropertyValidator.clean_property(prop_key, extracted_val, object_key, 
                                                                                self.is_card_visual, self.visual_type)
                                    if cleaned_val is not None:
                                        processed_props[prop_key] = cleaned_val
                            
                            if processed_props:
                                # Store with $id format for wildcard
                                state_item = {"$id": selector_id}
                                state_item.update(processed_props)
                                self.interaction_states[object_key].append(state_item)
                            
                            # Skip adding to preset config
                            continue

            if not self.should_process_object(object_key) or not isinstance(object_items, list):
                continue
            
            final_states_for_object = []
            
            for item in self._get_valid_items(object_items):
                selector = item.get("selector")
                properties = item.get("properties", {})
                
                # Skip only metadata selectors
                if selector and 'metadata' in selector:
                    continue
                
                # Skip interaction states for preset config
                if (is_slicer and 
                    object_key in SLICER_OBJECTS_NEEDING_ID and  # Changed from INTERACTION_STATE_OBJECTS
                    selector and isinstance(selector, dict) and 
                    "id" in selector and selector["id"] in VALID_INTERACTION_SELECTORS):
                    continue
                
                # Process all properties
                current_state_item = {}
                
                for prop_key, prop_val in properties.items():
                    if not isinstance(prop_key, str) or prop_key.startswith("dynamic"):
                        continue
                    
                    extracted_val = ValueExtractor.extract_value(prop_val)
                    if extracted_val is not None:
                        # Pass visual_type to clean_property
                        cleaned_val = PropertyValidator.clean_property(prop_key, extracted_val, object_key, 
                                                                    self.is_card_visual, self.visual_type)
                        if cleaned_val is not None:
                            current_state_item[prop_key] = cleaned_val
                
                # Add selector in the correct format
                if current_state_item:
                    if selector and isinstance(selector, dict) and "id" in selector:
                        current_state_item["selector"] = selector
                    elif selector:
                        current_state_item["selector"] = selector
                        
                    final_states_for_object.append(current_state_item)

            if final_states_for_object:
                visual_config[object_key] = final_states_for_object
        
        # Add stylePreset if it exists for slicers
        if is_slicer and "stylePreset" in objects:
            stylePreset_items = objects["stylePreset"]
            if isinstance(stylePreset_items, list) and stylePreset_items:
                for item in stylePreset_items:
                    if isinstance(item, dict) and "properties" in item:
                        props = item["properties"]
                        if "name" in props:
                            name_val = ValueExtractor.extract_value(props["name"])
                            if name_val:
                                visual_config["stylePreset"] = [{"name": name_val}]
        
        if visual_config:
            preset_name = f"{self.clean_name(display_name)}_Style_{preset_counter}"
            return VisualConfig(self.visual_type, preset_name, visual_config, self.page_type)
        
        return None

