        "valueAxis": "label",
        "categoryAxis": "label",
        "labels": "label",
        "dataLabels": "label",
        "totals": "boldLabel",
        "subTotals": "label",
        "grandTotals": "boldLabel",
        "seriesLabels": "label",
        "error": "smallLabel",
        "calloutValue": "callout",
        "header": "header",
        "values": "label",
        "rowHeaders": "label",
        "columnHeaders": "label",
        "wordWrap": "label",
        "detail": "smallLightLabel",
        "trendline": "label"
    }
    
    # Font properties that should be converted
    FONT_PROPERTIES = {
        "fontFamily": "fontFace",
        "fontSize": "fontSize",
        "fontColor": "color",
        "color": "color",
        "bold": "bold",
        "italic": "italic",
        "underline": "underline",
        "fontBold": "bold",
        "fontItalic": "italic",
        "fontUnderline": "underline"
    }
    
    def __init__(self):
        self.text_classes = self.DEFAULT_TEXT_CLASSES.copy()
        self.extracted_font_styles = {}
    
    def convert_theme(self, theme: Dict[str, Any]) -> Dict[str, Any]:
        """Convert an entire theme to use text classes"""
        converted_theme = theme.copy()
        
        # Extract any existing text classes
        if "textClasses" in theme:
            self.text_classes.update(theme["textClasses"])
        
        # Extract common font styles from visual styles
        self._extract_font_styles(theme.get("visualStyles", {}))
        
        # Create optimized text classes based on extracted styles
        optimized_text_classes = self._create_optimized_text_classes()
        
        # Convert visual styles to use text classes
        converted_visual_styles = self._convert_visual_styles(theme.get("visualStyles", {}))
        
        # Build the final theme
        converted_theme["textClasses"] = optimized_text_classes
        converted_theme["visualStyles"] = converted_visual_styles
        
        return converted_theme
    
    def _extract_font_styles(self, visual_styles: Dict[str, Any]) -> None:
        """Extract font styles from visual styles for analysis"""
        for visual_type, visual_config in visual_styles.items():
            if isinstance(visual_config, dict):
                for preset_name, preset_config in visual_config.items():
                    if isinstance(preset_config, dict):
                        for object_name, object_items in preset_config.items():
                            if isinstance(object_items, list):
                                for item in object_items:
                                    if isinstance(item, dict):
                                        font_props = self._extract_font_properties(item)
                                        if font_props:
                                            key = self._create_style_key(font_props)
                                            if key not in self.extracted_font_styles:
                                                self.extracted_font_styles[key] = {
                                                    "style": font_props,
                                                    "usage": []
                                                }
                                            self.extracted_font_styles[key]["usage"].append({
                                                "visual": visual_type,
                                                "preset": preset_name,
                                                "object": object_name
                                            })
    
    def _extract_font_properties(self, item: Dict[str, Any]) -> Dict[str, Any]:
        """Extract font-related properties from an item"""
        font_props = {}
        
        for prop, value in item.items():
            if prop in self.FONT_PROPERTIES:
                if prop in ["fontColor", "color"] and isinstance(value, dict):
                    # Extract color from solid fill
                    if "solid" in value and "color" in value["solid"]:
                        font_props["color"] = value["solid"]["color"]
                elif prop == "fontFamily":
                    # Standardize font family
                    font_props["fontFace"] = self._standardize_font_family(value)
                elif prop in ["bold", "fontBold", "italic", "fontItalic", "underline", "fontUnderline"]:
                    # Boolean properties
                    font_props[self.FONT_PROPERTIES[prop]] = value
                else:
                    font_props[self.FONT_PROPERTIES.get(prop, prop)] = value
        
        return font_props
    
    def _standardize_font_family(self, font_family: str) -> str:
        """Standardize font family string"""
        if not isinstance(font_family, str):
            return "Segoe UI"
        
        # Clean up the font family string
        cleaned = font_family.replace('\\"', '"').strip("'\"")
        parts = cleaned.split(',')
        
        for part in parts:
            part = part.strip().strip("'\"")
            # Skip wf_ prefixed fonts and empty parts
            if part and not part.startswith('wf_'):
                return part
        
        return "Segoe UI"
    
    def _create_style_key(self, style: Dict[str, Any]) -> str:
        """Create a unique key for a font style"""
        # Sort keys for consistent comparison
        sorted_items = sorted(style.items())
        return json.dumps(sorted_items, sort_keys=True)
    
    def _create_optimized_text_classes(self) -> Dict[str, Dict[str, Any]]:
        """Create optimized text classes based on usage patterns"""
        # Start with default text classes
        optimized_classes = self.DEFAULT_TEXT_CLASSES.copy()
        
        # Analyze extracted styles and create new classes if needed
        style_usage_count = {}
        for key, data in self.extracted_font_styles.items():
            usage_count = len(data["usage"])
            if usage_count > 2:  # Only create new classes for frequently used styles
                style_usage_count[key] = {
                    "style": data["style"],
                    "count": usage_count,
                    "usage": data["usage"]
                }
        
        # You can extend this to create custom text classes based on usage patterns
        # For now, we'll use the default mapping
        
        return optimized_classes
    
    def _convert_visual_styles(self, visual_styles: Dict[str, Any]) -> Dict[str, Any]:
        """Convert visual styles to use text classes"""
        converted = {}
        
        for visual_type, visual_config in visual_styles.items():
            if visual_type == "*":
                # Handle global wildcard - convert to double wildcard
                converted["*"] = {
                    "*": self._convert_wildcard_content(visual_config)
                }
            else:
                converted[visual_type] = {}
                
                if isinstance(visual_config, dict):
                    for preset_name, preset_config in visual_config.items():
                        if preset_name == "*":
                            # Visual-specific wildcard
                            converted[visual_type]["*"] = self._convert_preset_config(preset_config)
                        else:
                            # Regular preset
                            converted[visual_type][preset_name] = self._convert_preset_config(preset_config)
        
        return converted
    
    def _convert_wildcard_content(self, config: Dict[str, Any]) -> Dict[str, Any]:
        """Convert wildcard content, handling both direct properties and nested objects"""
        converted = {}
        
        # If config contains objects with arrays (standard format)
        for object_name, object_items in config.items():
            if isinstance(object_items, list):
                converted_items = []
                
                for item in object_items:
                    if isinstance(item, dict):
                        converted_item = self._convert_item_with_text_class(item, object_name)
                        converted_items.append(converted_item)
                    else:
                        converted_items.append(item)
                
                if converted_items:
                    converted[object_name] = converted_items
            else:
                # Handle non-list properties
                converted[object_name] = object_items
        
        return converted
    
    def _convert_preset_config(self, config: Dict[str, Any]) -> Dict[str, Any]:
        """Convert a preset configuration to use text classes"""
        converted = {}
        
        for object_name, object_items in config.items():
            if isinstance(object_items, list):
                converted_items = []
                
                for item in object_items:
                    if isinstance(item, dict):
                        converted_item = self._convert_item_with_text_class(item, object_name)
                        converted_items.append(converted_item)
                    else:
                        converted_items.append(item)
                
                if converted_items:
                    converted[object_name] = converted_items
            else:
                converted[object_name] = object_items
        
        return converted
    
    def _convert_item_with_text_class(self, item: Dict[str, Any], object_name: str) -> Dict[str, Any]:
        """Convert an item to use text class if applicable"""
        # Check if this object should use a text class
        if object_name in self.TEXT_CLASS_MAPPINGS:
            text_class = self.TEXT_CLASS_MAPPINGS[object_name]
            
            # Extract font properties
            font_props = self._extract_font_properties(item)
            
            if font_props:
                # Create new item without font properties
                converted_item = {}
                
                # Add text class reference
                converted_item["textClass"] = text_class
                
                # Copy non-font properties
                for prop, value in item.items():
                    if prop not in self.FONT_PROPERTIES and prop != "textClass":
                        converted_item[prop] = value
                
                # Check if we need to override any properties
                text_class_props = self.text_classes.get(text_class, {})
                for prop, value in font_props.items():
                    # If the property differs from the text class, keep it as override
                    if prop in text_class_props and value != text_class_props[prop]:
                        # Map back to theme property names
                        if prop == "fontFace":
                            converted_item["fontFamily"] = value
                        elif prop == "color" and object_name in ["title", "subTitle", "legend", "categoryAxis", "valueAxis"]:
                            converted_item["fontColor"] = {"solid": {"color": value}}
                        else:
                            converted_item[prop] = value
                
                return converted_item
        
        # No text class mapping - return original item
        return item


