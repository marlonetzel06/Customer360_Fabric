        self.visual_configs = defaultdict(list)
        self.default_configs = defaultdict(dict)  # Store default page visuals
        self.global_settings = {}  # Store global settings
        self.preset_counters = defaultdict(int)
        self.card_wildcard_configs = {}
        self.font_settings = {}
        self.page_config = {}
        self.preset_counters["_debug_count"] = 0  # Add debug counter
        self.preset_counters["_card_debug"] = 0  # Add card debug counter
        self.preset_counters["_card_empty"] = 0  # Add card empty counter
        self._interaction_states_collection = {}  # Store interaction states separately
    
    def _verify_theme_structure(self, theme_output: Dict[str, Any]) -> None:
        """Verify the theme structure is valid for Power BI"""
        print("\n🔍 Theme Structure Verification:")
        
        # Check if advancedSlicerVisual exists
        if "advancedSlicerVisual" in theme_output.get("visualStyles", {}):
            slicer_config = theme_output["visualStyles"]["advancedSlicerVisual"]
            
            if "*" in slicer_config:
                wildcard = slicer_config["*"]
                
                # Check fillCustom
                if "fillCustom" in wildcard:
                    fill_items = wildcard["fillCustom"]
                    print(f"  ✅ fillCustom found with {len(fill_items)} configurations")
                    
                    # Verify $id format
                    ids_found = {}
                    for item in fill_items:
                        if "$id" in item:
                            id_val = item["$id"]
                            ids_found[id_val] = item
                            
                    # Check each expected $id
                    expected = ["default", "interaction:hover", "selection:selected"]
                    for id_val in expected:
                        if id_val in ids_found:
                            props = [k for k in ids_found[id_val].keys() if k != "$id"]
                            print(f"    ✓ $id '{id_val}': {', '.join(props)}")
                        else:
                            print(f"    ❌ $id '{id_val}': MISSING")
                            
                    # Check if stylePreset is present
                    if "stylePreset" in wildcard:
                        preset = wildcard["stylePreset"]
                        if isinstance(preset, list) and preset and "name" in preset[0]:
                            print(f"  ✅ stylePreset found: {preset[0]['name']}")
                    else:
                        print("  ⚠️  stylePreset not found (optional)")
                else:
                    print("  ❌ fillCustom object not found")
                    
                # Verify font families don't have double quotes
                for obj_name, items in wildcard.items():
                    if isinstance(items, list):
                        for item in items:
                            if isinstance(item, dict) and "fontFamily" in item:
                                font = item["fontFamily"]
                                if "''" in font:
                                    print(f"  ⚠️  Double quote issue in {obj_name} fontFamily: {font[:30]}...")
            else:
                print("  ❌ Wildcard (*) section not found")
                
            # Check presets don't have interaction states
            for preset_name, preset_config in slicer_config.items():
                if preset_name != "*" and isinstance(preset_config, dict):
                    for obj_name in INTERACTION_STATE_OBJECTS:
                        if obj_name in preset_config:
                            print(f"  ❌ ERROR: Preset '{preset_name}' contains interaction state object '{obj_name}'")
        else:
            print("  ❌ advancedSlicerVisual not found in visualStyles")
            
    def generate_theme_from_report(self, report_path: str, output_dir: str = DEFAULT_OUTPUT_DIR, 
                                   interactive: bool = True) -> str:
        """Main method to generate theme from report - handles both old and new formats"""
        # Setup
        os.makedirs(output_dir, exist_ok=True)
        
        # Determine if this is old format (report.json) or new format (folder structure)
        if os.path.isfile(report_path) and report_path.endswith('.json'):
            # Old format - single report.json file
            report_name = self._extract_report_name(report_path)
            clean_report_name = self._clean_report_name(report_name)
            data = self._load_report_data(report_path)
            self._process_report_sections(data)
        else:
            # New format - folder structure with individual visual.json files
            if os.path.isfile(report_path):
                # If a file was passed, get the parent Report folder
                report_dir = report_path
                while report_dir and not report_dir.endswith('.Report'):
                    report_dir = os.path.dirname(report_dir)
            else:
                report_dir = report_path
                
            if not report_dir or not os.path.exists(report_dir):
                raise ValueError(f"Could not find valid .Report directory from: {report_path}")
            
            report_name = os.path.basename(report_dir).replace('.Report', '')
            clean_report_name = self._clean_report_name(report_name)
            
            # Process new folder structure
            self._process_folder_structure(report_dir)
        
        # Check if any visuals were processed
        if not self.visual_configs and not self.default_configs:
            print("⚠️  Warning: No visual configurations were extracted from the report")
        
        # Ask about font standardization
        standardize_fonts = False
        if interactive and (self.visual_configs or self.default_configs):
            print("\n" + "="*60)
            print("🎨 FONT STANDARDIZATION OPTION")
            print("="*60)
            print("\nWould you like to standardize font settings across all visuals?")
            print("This will extract common font properties and apply them globally")
            print("for consistent typography throughout your reports.")
            print("\nOptions:")
            print("  [Y] Yes - Create consistent font settings (recommended)")
            print("  [N] No  - Keep individual visual font settings")
            
            while True:
                choice = input("\nYour choice (Y/N): ").strip().upper()
                if choice in ['Y', 'YES']:
                    standardize_fonts = True
                    print("✅ Font standardization enabled")
                    break
                elif choice in ['N', 'NO']:
                    standardize_fonts = False
                    print("✅ Keeping individual font settings")
                    break
                else:
                    print("❌ Please enter Y or N")
        
        # Generate theme
        theme_output = self._build_theme_structure(report_name)
        theme_output["dataColors"] = self.palette.build_palette()
        
        if standardize_fonts:
            # Extract common font settings before building visual styles
            self.font_settings = self._extract_common_font_settings()
            theme_output["visualStyles"] = self._build_visual_styles_with_standardized_fonts()
        else:
            theme_output["visualStyles"] = self._build_visual_styles()
        
        # Verify theme structure
        self._verify_theme_structure(theme_output)
        
        # Save theme
        theme_path = self._save_theme_file(theme_output, clean_report_name, output_dir)
        self._print_summary(theme_path, report_name, theme_output)
        
        return theme_path
    
    def _extract_report_name(self, report_path: str) -> str:
        """Extract report name from file path or folder"""
        if os.path.isdir(report_path):
            # For folder input, use the folder name
            if report_path.endswith('.Report'):
                return os.path.basename(report_path).replace('.Report', '')
            else:
                return os.path.basename(report_path)
        else:
            # For file input
            report_filename = os.path.basename(report_path)
            report_dir = os.path.dirname(report_path)
            parent_dir = os.path.basename(report_dir)
            
            if parent_dir.endswith('.Report'):
                return parent_dir.replace('.Report', '')
            else:
                return os.path.splitext(report_filename)[0]
    
    def _clean_report_name(self, report_name: str) -> str:
        """Clean report name for filenames"""
        return re.sub(r'[^\w\s-]', '', report_name).replace(' ', '_')
    
    def _load_report_data(self, report_json_path: str) -> Dict[str, Any]:
        """Load report JSON data"""
        print(f"DEBUG _load_report_data: Trying to load {report_json_path}")
        with open(report_json_path, "r", encoding="utf-8") as f:
            return json.load(f)
    
    def _process_report_sections(self, data: Dict[str, Any]) -> None:
        """Process all sections in the report (old format)"""
        for section_index, section in enumerate(data.get("sections", [])):
            display_name = section.get("displayName", f"Page_{section_index}")
            page_type = self._determine_page_type(display_name)
            
            visual_containers = section.get("visualContainers", [])
            
            for vc in visual_containers:
                self._process_visual_container(vc, display_name, page_type)
    
    def _determine_page_type(self, display_name: str) -> str:
        """Determine the page type based on display name"""
        display_name_lower = display_name.lower()
        print(f"  🔍 Checking page type for: '{display_name}' (lowercase: '{display_name_lower}')")
        
        if display_name_lower == "default":
            print(f"    → Detected as DEFAULT page")
            return "default"
        elif display_name_lower == "global":
            print(f"    → Detected as GLOBAL page")
            return "global"
        else:
            print(f"    → Detected as REGULAR page")
            return "regular"
    
    def _process_folder_structure(self, report_dir: str) -> None:
        """Process new folder structure with individual visual.json files"""
        print(f"📂 Processing report folder: {report_dir}")
        
        # Look for definition/pages folder
        pages_dir = os.path.join(report_dir, "definition", "pages")
        if not os.path.exists(pages_dir):
            raise ValueError(f"Could not find pages directory at: {pages_dir}")
        
        visual_count = 0
        page_count = 0
        
        # Iterate through page folders
        for page_folder in os.listdir(pages_dir):
            page_path = os.path.join(pages_dir, page_folder)
            if not os.path.isdir(page_path):
                continue
            
            page_count += 1
            
            # Try to get page name from page.json if it exists
            page_json_path = os.path.join(page_path, "page.json")
            display_name = f"Page_{page_count}"
            
            if os.path.exists(page_json_path):
                try:
                    with open(page_json_path, "r", encoding="utf-8") as f:
                        page_data = json.load(f)
                        # Try different possible locations for the display name
                        if "displayName" in page_data:
                            display_name = page_data["displayName"]
                        elif "name" in page_data:
                            display_name = page_data["name"]
                        elif "config" in page_data and isinstance(page_data["config"], dict):
                            display_name = page_data["config"].get("displayName", display_name)
                        
                        print(f"  📄 Processing page: {display_name}")
                except Exception as e:
                    print(f"  ⚠️  Could not read page name from {page_json_path}: {e}")
            
            # Determine page type
            page_type = self._determine_page_type(display_name)
            
            # Look for visuals folder
            visuals_dir = os.path.join(page_path, "visuals")
            if not os.path.exists(visuals_dir):
                continue
            
            # Count visuals in this page
            page_visual_count = 0
            
            # Process each visual folder
            for visual_folder in os.listdir(visuals_dir):
                visual_json_path = os.path.join(visuals_dir, visual_folder, "visual.json")
                if os.path.exists(visual_json_path):
                    page_visual_count += 1
                    visual_count += 1
                    self._process_visual_json_file(visual_json_path, display_name, page_type)
            
            if page_visual_count > 0:
                print(f"    ✓ Processed {page_visual_count} visuals")
        
        print(f"\n✅ Total: {visual_count} visuals across {page_count} pages")
    
    def _process_visual_json_file(self, visual_json_path: str, display_name: str, page_type: str) -> None:
        """Process a single visual.json file with page type awareness."""
        try:
            with open(visual_json_path, "r", encoding="utf-8") as f:
                visual_data = json.load(f)
            
            # Determine visual type and objects
            visual_info = visual_data.get("visual", visual_data)
            visual_type = visual_info.get("visualType", "UnknownType")
            objects = visual_info.get("objects", {})
            container_objects = visual_info.get("visualContainerObjects", {})
            
            # Debug print for global page
            if page_type == "global":
                print(f"    🌐 Processing GLOBAL page visual: {visual_type}")
                print(f"       - Has objects: {bool(objects)}")
                print(f"       - Has container objects: {bool(container_objects)}")
            
            # Merge container objects (like title, border) into main objects
            if container_objects:
                for key, value in container_objects.items():
                    if key not in ["general", "visualTooltip", "visualHeader"] and key not in objects:
                        objects[key] = value
            
            if not objects or visual_type == "textbox":
                return
            
            # Create appropriate processor with page type
            processor = CardVisualProcessor(visual_type, page_type) if visual_type in CARD_VISUALS else StandardVisualProcessor(visual_type, page_type)
            
            self.preset_counters[visual_type] += 1
            
            # Process the visual's configuration
            visual_config_obj = processor.process_visual_config(objects, display_name, self.preset_counters[visual_type])
            
            # Check if the processed configuration is valid and should be added to the theme
            if visual_config_obj and visual_config_obj.has_meaningful_config():
                if page_type == "default":
                    # Store as default configuration for this visual type
                    print(f"    📌 Storing as DEFAULT config for {visual_type}")
                    self.default_configs[visual_type] = visual_config_obj.config
                elif page_type == "global":
                    # Extract global settings
                    print(f"    🌐 Extracting GLOBAL settings from {visual_type}")
                    print(f"       Config keys: {list(visual_config_obj.config.keys())}")
                    self._extract_global_settings(visual_config_obj.config)
                else:
                    # Regular page - add as preset
                    self.visual_configs[visual_type].append(visual_config_obj)
            
            # For interaction state visuals, also collect interaction states
            if visual_type in INTERACTION_STATE_VISUALS and hasattr(processor, 'interaction_states'):
                if visual_type not in self._interaction_states_collection:
                    self._interaction_states_collection[visual_type] = defaultdict(list)
                
                for object_name, states in processor.interaction_states.items():
                    self._interaction_states_collection[visual_type][object_name].extend(states)
            
            if isinstance(processor, CardVisualProcessor) and visual_type not in self.card_wildcard_configs:
                self.card_wildcard_configs[visual_type] = visual_config_obj.config
            
            for color in processor.palette.colors:
                self.palette.add_color(color)

        except Exception as e:
            print(f"⚠️  Warning: Could not process visual at {visual_json_path}: {str(e)}")

    def _process_visual_container(self, vc: Dict[str, Any], display_name: str, page_type: str) -> None:
        """Process a single visual container with page type awareness"""
        if not isinstance(vc, dict):
            return
            
        config_text = vc.get("config")
        if not config_text or not isinstance(config_text, str):
            return
        
        try:
            config = json.loads(config_text)
        except json.JSONDecodeError:
            return
        
        if not isinstance(config, dict):
            return
            
        single_visual = config.get("singleVisual")
        if not single_visual or not isinstance(single_visual, dict):
            return
        
        visual_type = single_visual.get("visualType", "UnknownType")
        objects = single_visual.get("objects", {})
        
        # For Global page, also check visualContainerObjects for container-level settings
        if page_type == "global":
            container_objects = single_visual.get("visualContainerObjects", {})
            if container_objects:
                # These are more likely to contain global settings like title, background, etc.
                self._extract_global_settings(container_objects)
        
        if not objects:
            return
        
        # Create appropriate processor and process visual with page type
        if visual_type in CARD_VISUALS:
            processor = CardVisualProcessor(visual_type, page_type)
        else:
            processor = StandardVisualProcessor(visual_type, page_type)
            
        self.preset_counters[visual_type] += 1
        
        visual_config = processor.process_visual_config(objects, display_name, self.preset_counters[visual_type])
        
        if visual_config and visual_config.has_meaningful_config():
            if page_type == "default":
                # Store as default configuration
                self.default_configs[visual_type] = visual_config.config
            elif page_type == "global":
                # Extract global settings
                self._extract_global_settings(visual_config.config)
            else:
                # Regular page - add as preset
                self.visual_configs[visual_type].append(visual_config)
            
            # For interaction state visuals, also collect interaction states
            if visual_type in INTERACTION_STATE_VISUALS and hasattr(processor, 'interaction_states'):
                if visual_type not in self._interaction_states_collection:
                    self._interaction_states_collection[visual_type] = defaultdict(list)
                
                for object_name, states in processor.interaction_states.items():
                    self._interaction_states_collection[visual_type][object_name].extend(states)
            
            # For card visuals, store first config as wildcard
            if isinstance(processor, CardVisualProcessor) and visual_type not in self.card_wildcard_configs:
                self.card_wildcard_configs[visual_type] = visual_config.config
            
            # Merge colors from processor
            for color in processor.palette.colors:
                self.palette.add_color(color)
    
    def _extract_global_settings(self, config: Dict[str, Any]) -> None:
        """Extract global settings from a visual configuration"""
        print(f"    🌐 _extract_global_settings called with config keys: {list(config.keys())}")
        
        for object_name, items in config.items():
            # Skip visual-specific objects that shouldn't be global
            if object_name in ["stylePreset", "visualTooltip", "visualHeader"]:
                print(f"       - Skipping {object_name} (visual-specific)")
                continue
                
            # Add all other objects as potential global settings
            if object_name not in self.global_settings:
                self.global_settings[object_name] = []
                print(f"       - Creating new global setting: {object_name}")
            
            # Add unique items
            items_added = 0
            for item in items:
                if isinstance(item, dict):
                    # Check if this exact configuration already exists
                    item_str = json.dumps(item, sort_keys=True)
                    exists = False
                    for existing in self.global_settings[object_name]:
                        if json.dumps(existing, sort_keys=True) == item_str:
                            exists = True
                            break
                    if not exists:
                        self.global_settings[object_name].append(item)
                        items_added += 1
            
            if items_added > 0:
                print(f"       - Added {items_added} items to {object_name}")

    def _build_theme_structure(self, report_name: str) -> Dict[str, Any]:
        """Build the basic theme structure"""
        return {
            "$schema": THEME_SCHEMA_URL,
            "name": f"Generated Theme from {report_name}",
            "dataColors": [],
            "visualStyles": {}
        }
    
    def _build_visual_styles(self) -> Dict[str, Any]:
        """Build visual styles section of theme with Default/Global page logic and text classes."""
        visual_styles = {}
        
        # Create the double wildcard structure with global settings
        global_wildcard = {}
        
        # Add global settings
        if self.global_settings:
            global_wildcard.update(self.global_settings.copy())
        
        # Convert font properties in global settings to text classes
        global_wildcard = self._apply_text_classes_to_config(global_wildcard)
        
        # Add the double wildcard
        visual_styles["*"] = {"*": global_wildcard}

        # Process each visual type
        all_visual_types = set(self.visual_configs.keys()) | set(self.default_configs.keys())
        
        for visual_type in all_visual_types:
            configs = self.visual_configs.get(visual_type, [])
            default_config = self.default_configs.get(visual_type)
            
            if visual_type in CARD_VISUALS:
                visual_styles[visual_type] = {}
                
                # Use default config as wildcard if available, otherwise use card wildcard config
                wildcard_config = None
                if default_config:
                    wildcard_config = default_config.copy()
                elif visual_type in self.card_wildcard_configs:
                    wildcard_config = self.card_wildcard_configs[visual_type].copy()
                
                if wildcard_config:
                    # Apply text classes to wildcard
                    wildcard_config = self._apply_text_classes_to_config(wildcard_config)
                    visual_styles[visual_type]["*"] = wildcard_config
                
                # Add presets from regular pages
                for config in configs:
                    preset_config = self._apply_text_classes_to_config(config.config.copy())
                    visual_styles[visual_type][config.preset_name] = preset_config
                    
            elif visual_type in NO_PRESET_VISUALS:
                # Table/matrix/pivot visuals don't support presets, only wildcard
                merged_config = default_config.copy() if default_config else {}
                
                # Merge in configs from regular pages
                for config in configs:
                    for object_name, items in config.config.items():
                        if object_name not in merged_config:
                            merged_config[object_name] = []
                        merged_config[object_name].extend(items)
                
                if merged_config:
                    # Remove duplicates while preserving order AND selectors
                    for object_name in merged_config:
                        seen_items = {}
                        unique_items = []
                        
                        for item in merged_config[object_name]:
                            item_key = json.dumps(item, sort_keys=True)
                            
                            if item_key not in seen_items:
                                seen_items[item_key] = True
                                unique_items.append(item)
                        
                        merged_config[object_name] = unique_items
                    
                    # Apply text classes
                    merged_config = self._apply_text_classes_to_config(merged_config)
                    visual_styles[visual_type] = {"*": merged_config}
                    
            elif visual_type in INTERACTION_STATE_VISUALS:
                # Special handling for interaction state visuals
                wildcard_config = default_config.copy() if default_config else {}
                
                # Merge configs from regular pages into wildcard
                for config in configs:
                    for object_name, items in config.config.items():
                        if object_name not in wildcard_config:
                            wildcard_config[object_name] = []
                        wildcard_config[object_name].extend(items)
                
                # Add collected interaction states
                if visual_type in self._interaction_states_collection:
                    for object_name, states in self._interaction_states_collection[visual_type].items():
                        if object_name not in wildcard_config:
                            wildcard_config[object_name] = []
                        wildcard_config[object_name].extend(states)
                
                # Build the visual style - ONLY wildcard, no presets
                if wildcard_config:
                    wildcard = {}
                    
                    # Add all objects to wildcard
                    for object_name, items in wildcard_config.items():
                        # Remove duplicates while preserving $id items
                        seen_items = {}
                        unique_items = []
                        for item in items:
                            # For items with $id, use $id as key
                            if "$id" in item:
                                key = f"$id:{item['$id']}"
                            else:
                                key = json.dumps(item, sort_keys=True)
                            
                            if key not in seen_items:
                                seen_items[key] = True
                                unique_items.append(item)
                        wildcard[object_name] = unique_items
                    
                    # Apply text classes
                    wildcard = self._apply_text_classes_to_config(wildcard)
                    visual_styles[visual_type] = {"*": wildcard}
            
            else:
                # Standard visuals with preset support
                if default_config or configs:
                    visual_styles[visual_type] = {}
                    
                    # Use default config as wildcard if available
                    if default_config:
                        wildcard_config = self._apply_text_classes_to_config(default_config.copy())
                        visual_styles[visual_type]["*"] = wildcard_config
                    elif configs:
                        # If no default, use the first preset's config as wildcard base
                        visual_styles[visual_type]["*"] = {"stylePreset": [{"name": configs[0].preset_name}]}
                    
                    # Add global styling for specific visual types
                    self._add_global_styling(visual_styles[visual_type], visual_type)
                    
                    # Add individual presets from regular pages
                    for config in configs:
                        if config.config:
                            preset_config = self._apply_text_classes_to_config(config.config.copy())
                            visual_styles[visual_type][config.preset_name] = self._process_preset_config(preset_config)

        return {k: v for k, v in visual_styles.items() if v}


    def _apply_text_classes_to_config(self, config: Dict[str, Any]) -> Dict[str, Any]:
        """Apply text classes to a configuration"""
        converted = {}
        
        # Mapping of objects to text classes
        text_class_mappings = {
            "title": "title",
            "subTitle": "label",
            "legend": "label",
            "valueAxis": "label",
            "categoryAxis": "label",
            "labels": "label",
            "dataLabels": "label",
            "totals": "boldLabel",
            "subTotals": "label",
            "grandTotals": "boldLabel",
            "seriesLabels": "label",
            "error": "smallLabel",
            "calloutValue": "callout",
            "header": "header",
            "values": "label",
            "rowHeaders": "label",
            "columnHeaders": "label",
            "detail": "smallLightLabel",
            "trendline": "label"
        }
        
        for object_name, object_items in config.items():
            if isinstance(object_items, list):
                converted_items = []
                
                for item in object_items:
                    if isinstance(item, dict) and object_name in text_class_mappings:
                        # Convert to use text class
                        converted_item = self._convert_to_text_class(item, text_class_mappings[object_name])
                        converted_items.append(converted_item)
                    else:
                        converted_items.append(item)
                
                converted[object_name] = converted_items
            else:
                converted[object_name] = object_items
        
        return converted


    def _convert_to_text_class(self, item: Dict[str, Any], text_class: str) -> Dict[str, Any]:
        """Convert an item to use text class"""
        font_properties = ["fontFamily", "fontSize", "fontColor", "color", "bold", "italic", 
                        "underline", "fontBold", "fontItalic", "fontUnderline"]
        
        # Create new item with text class
        converted = {"textClass": text_class}
        
        # Copy non-font properties
        for prop, value in item.items():
            if prop not in font_properties:
                converted[prop] = value
        
        return converted


