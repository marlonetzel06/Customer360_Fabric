    def _process_item_properties(self, properties: Dict[str, Any], object_key: str) -> Optional[Dict[str, Any]]:
        """Process properties for a single item - be very permissive"""
        if not isinstance(properties, dict): 
            return None
            
        processed = {}
        for prop_key, prop_value in properties.items():
            if not isinstance(prop_key, str): 
                continue
            
            # Extract the value
            extracted = ValueExtractor.extract_value(prop_value)
            if extracted is None: 
                continue
            
            # Be more permissive with validation
            if prop_key in CARD_INVALID_PROPERTIES:
                continue
                
            # Clean the property
            cleaned = PropertyValidator.clean_property(prop_key, extracted, object_key, True, self.visual_type)
            if cleaned is not None:
                processed[prop_key] = cleaned
        
        return processed if processed else None


