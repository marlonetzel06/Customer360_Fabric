def create_theme_color_reference(color_id: int, percent: int = 0) -> Dict[str, Any]:
    """Create a theme color reference object"""
    return {
        "expr": {
            "ThemeDataColor": {
                "ColorId": color_id,
                "Percent": percent
            }
        }
    }


@dataclass
class ColorPalette:
    """Manages the theme color palette"""
    colors: List[str] = field(default_factory=list)
    
    def add_color(self, color: str) -> bool:
        """Add a color to the palette if it's valid and not already present"""
        if self.is_valid_hex_color(color) and color.upper() not in [c.upper() for c in self.colors]:
            self.colors.append(color)
            return True
        return False
    
    def build_palette(self, max_colors: int = 7) -> List[str]:
        """Build a complete color palette with defaults if needed"""
        # Filter out white and take first max_colors
        base_colors = [c for c in self.colors if c.upper() != "#FFFFFF"][:max_colors]
        
        # Add default colors if needed
        for default_color in DEFAULT_COLORS:
            if len(base_colors) >= max_colors:
                break
            if default_color not in base_colors:
                base_colors.append(default_color)
        
        # Ensure we have exactly max_colors before adding white
        while len(base_colors) < max_colors:
            base_colors.append("#CCCCCC")
        
        # Add white as the final color
        base_colors.append("#FFFFFF")
        return base_colors
    
    @staticmethod
    def is_valid_hex_color(color: str) -> bool:
        """Check if a string is a valid hex color"""
        return isinstance(color, str) and bool(COLOR_PATTERN.match(color))

class PageInfoExtractor:
    """Extract page-level information from Power BI report pages"""
    
    # Page properties that should be extracted for themes
    PAGE_THEME_PROPERTIES = {
        "background", "wallpaper", "outspace", "filterPaneBackground"
    }
    
    def __init__(self):
        self.page_configs = {}
        self.page_wildcard_config = {}
    
    def extract_page_info_from_folder(self, report_dir: str, target_page_names: List[str] = ["Page"]) -> Dict[str, Any]:
        """
        Extract page information from report folder structure
        
        Args:
            report_dir: Path to the .Report directory
            target_page_names: List of page names to look for (default: ["Page"])
        
        Returns:
            Dictionary with page configurations
        """
        pages_dir = os.path.join(report_dir, "definition", "pages")
        if not os.path.exists(pages_dir):
            print(f"⚠️  Pages directory not found: {pages_dir}")
            return {}
        
        # Iterate through page folders
        for page_folder in os.listdir(pages_dir):
            page_path = os.path.join(pages_dir, page_folder)
            if not os.path.isdir(page_path):
                continue
            
            # Read page.json
            page_json_path = os.path.join(page_path, "page.json")
            if os.path.exists(page_json_path):
                try:
                    with open(page_json_path, "r", encoding="utf-8") as f:
                        page_data = json.load(f)
                    
                    # Extract page name
                    page_name = self._get_page_name(page_data)
                    
                    # Check if this is a page we're interested in
                    if page_name in target_page_names:
                        print(f"  📄 Found target page: '{page_name}'")
                        page_config = self._extract_page_config(page_data)
                        if page_config:
                            self.page_configs[page_name] = page_config
                            # Use first matching page for wildcard
                            if not self.page_wildcard_config:
                                self.page_wildcard_config = page_config
                    
                except Exception as e:
                    print(f"  ⚠️  Error reading page.json at {page_json_path}: {e}")
        
        return self._build_page_theme_config()
    
    def extract_page_info_from_report_json(self, report_data: Dict[str, Any], target_page_names: List[str] = ["Page"]) -> Dict[str, Any]:
        """
        Extract page information from old-style report.json
        
        Args:
            report_data: Parsed report.json data
            target_page_names: List of page names to look for
        
        Returns:
            Dictionary with page configurations
        """
        for section in report_data.get("sections", []):
            page_name = section.get("displayName", "")
            
            if page_name in target_page_names:
                print(f"  📄 Found target page: '{page_name}'")
                
                # Extract page configuration from config string
                config_str = section.get("config", "")
                if config_str:
                    try:
                        config = json.loads(config_str)
                        page_config = self._extract_page_config_from_section(config)
                        if page_config:
                            self.page_configs[page_name] = page_config
                            if not self.page_wildcard_config:
                                self.page_wildcard_config = page_config
                    except json.JSONDecodeError:
                        print(f"  ⚠️  Could not parse config for page '{page_name}'")
        
        return self._build_page_theme_config()
    
    def _get_page_name(self, page_data: Dict[str, Any]) -> str:
        """Extract page name from page data"""
        # Try different possible locations
        if "displayName" in page_data:
            return page_data["displayName"]
        elif "name" in page_data:
            return page_data["name"]
        elif "config" in page_data and isinstance(page_data["config"], dict):
            return page_data["config"].get("displayName", "Unknown")
        return "Unknown"
    
    def _extract_page_config(self, page_data: Dict[str, Any]) -> Dict[str, Any]:
        """Extract theme-relevant configuration from page data"""
        theme_config = {}
        
        # Look for page objects in different possible locations
        page_objects = None
        
        # Try direct objects
        if "objects" in page_data:
            page_objects = page_data["objects"]
        # Try in config
        elif "config" in page_data and isinstance(page_data["config"], dict):
            if "objects" in page_data["config"]:
                page_objects = page_data["config"]["objects"]
            # Sometimes it might be in a parsed format
            elif isinstance(page_data["config"], str):
                try:
                    config = json.loads(page_data["config"])
                    page_objects = config.get("objects")
                except:
                    pass
        
        if page_objects:
            # Extract relevant page properties
            for prop in self.PAGE_THEME_PROPERTIES:
                if prop in page_objects:
                    processed_prop = self._process_page_property(prop, page_objects[prop])
                    if processed_prop:
                        theme_config[prop] = processed_prop
        
        return theme_config
    
    def _extract_page_config_from_section(self, config: Dict[str, Any]) -> Dict[str, Any]:
        """Extract page config from old-style section config"""
        theme_config = {}
        
        # Look for page objects
        page_objects = config.get("objects", {})
        
        for prop in self.PAGE_THEME_PROPERTIES:
            if prop in page_objects:
                processed_prop = self._process_page_property(prop, page_objects[prop])
                if processed_prop:
                    theme_config[prop] = processed_prop
        
        return theme_config
    
    def _process_page_property(self, prop_name: str, prop_value: Any) -> Optional[List[Dict[str, Any]]]:
        """Process a page property for theme inclusion"""
        if not isinstance(prop_value, list):
            return None
        
        processed_items = []
        
        for item in prop_value:
            if not isinstance(item, dict) or "properties" not in item:
                continue
            
            properties = item["properties"]
            processed_props = {}
            
            # Handle background image
            if prop_name == "background" and "image" in properties:
                image_config = self._extract_image_config(properties["image"])
                if image_config:
                    processed_props["image"] = image_config
            
            # Handle transparency
            if "transparency" in properties:
                processed_props["transparency"] = self._extract_value(properties["transparency"])
            
            # Handle color
            if "color" in properties:
                color_val = self._extract_color_value(properties["color"])
                if color_val:
                    processed_props["color"] = color_val
            
            if processed_props:
                processed_items.append(processed_props)
        
        return processed_items if processed_items else None
    
    def _extract_image_config(self, image_value: Any) -> Optional[Dict[str, Any]]:
        """Extract image configuration"""
        if isinstance(image_value, dict) and "expr" in image_value:
            expr = image_value["expr"]
            if isinstance(expr, dict) and "ResourcePackageItem" in expr:
                # This is a packaged image - extract the reference
                item = expr["ResourcePackageItem"]
                if isinstance(item, dict):
                    return {
                        "name": item.get("ItemName", "Background Image"),
                        "url": f"Package:{item.get('PackageName', '')}/{item.get('ItemName', '')}",
                        "scaling": "Fit"
                    }
            elif isinstance(expr, dict) and "Literal" in expr:
                # URL-based image
                literal = expr["Literal"]
                if isinstance(literal, dict) and "Value" in literal:
                    url = literal["Value"].strip("'\"")
                    return {
                        "name": "Background Image",
                        "url": url,
                        "scaling": "Fit"
                    }
        return None
    
    def _extract_value(self, value: Any) -> Any:
        """Extract simple values"""
        if isinstance(value, dict) and "expr" in value:
            expr = value["expr"]
            if isinstance(expr, dict) and "Literal" in expr:
                literal = expr["Literal"]
                if isinstance(literal, dict) and "Value" in literal:
                    val = literal["Value"]
                    # Try to parse numeric values
                    if isinstance(val, str):
                        val = val.strip("'\"")
                        try:
                            if '.' in val:
                                return float(val)
                            else:
                                return int(val)
                        except:
                            return val
                    return val
        return value
    
    def _extract_color_value(self, color_value: Any) -> Optional[Dict[str, Any]]:
        """Extract color value"""
        if isinstance(color_value, dict) and "solid" in color_value:
            solid_color = color_value["solid"].get("color")
            if solid_color:
                return {"solid": {"color": solid_color}}
        return None
    
    def _build_page_theme_config(self) -> Dict[str, Any]:
        """Build the page configuration for the theme"""
        if not self.page_wildcard_config:
            return {}
        
        # Return page config with wildcard structure
        return {
            "page": {
                "*": self.page_wildcard_config
            }
        }


# Integration with ThemeGenerator
def add_page_extraction_to_theme_generator(theme_generator_class):
    """Add page extraction capabilities to ThemeGenerator"""
    
    # Add page extractor initialization
    original_init = theme_generator_class.__init__
    
    def __init__(self):
        original_init(self)
        self.page_extractor = PageInfoExtractor()
    
    theme_generator_class.__init__ = __init__
    
    # Modify _process_folder_structure to extract page info
    original_process_folder = theme_generator_class._process_folder_structure
    
    def _process_folder_structure(self, report_dir: str) -> None:
        # Call original method
        original_process_folder(self, report_dir)
        
        # Extract page information
        print("\n📄 Extracting page-level configuration...")
        self.page_config = self._extract_page_information(report_dir)
        if self.page_config:
            print("  ✅ Page configuration found")
    
    theme_generator_class._process_folder_structure = _process_folder_structure
    
    # Modify _process_report_sections for old format
    original_process_sections = theme_generator_class._process_report_sections
    
    def _process_report_sections(self, data: Dict[str, Any]) -> None:
        # Call original method
        original_process_sections(self, data)
        
        # Extract page information
        print("\n📄 Extracting page-level information...")
        page_config = self.page_extractor.extract_page_info_from_report_json(data, ["Page"])
        if page_config:
            print("  ✅ Page configuration extracted")
    
    theme_generator_class._process_report_sections = _process_report_sections
    
    # Modify _build_theme_structure to include page config
    original_build_theme = theme_generator_class._build_theme_structure
    
    def _build_theme_structure(self, report_name: str) -> Dict[str, Any]:
        theme = original_build_theme(self, report_name)
        
        # Add page configuration if available
        if hasattr(self, 'page_config') and self.page_config:
            theme["page"] = {"*": self.page_config}
        
        return theme
    
    theme_generator_class._build_theme_structure = _build_theme_structure
    
    return theme_generator_class


